{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/api-server run build:vercel",
  "outputDirectory": "api",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api" }]
}
