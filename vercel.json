{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/api-server run build:vercel && BASE_PATH=/ VITE_API_BASE_URL= PORT=5000 pnpm --filter @workspace/inbox-ai run build",
  "outputDirectory": "artifacts/inbox-ai/dist/public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/cron/auto-label", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/daily-digest", "schedule": "0 12 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
